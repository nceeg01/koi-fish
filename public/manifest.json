{
  "manifest_version": 3,
  "name": "Koi-Zen: Browser Edition",
  "version": "1.0.0",
  "description": "A mindful companion that swims through your tabs.",
  "permissions": ["storage", "alarms"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
